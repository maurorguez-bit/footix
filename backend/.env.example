# ═══════════════════════════════════════════════════════════════
# FOOTIX BACKEND — Variables de entorno
# ═══════════════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────────────
# PRODUCCIÓN: URL de PostgreSQL de Railway o Neon
# Railway:  postgresql://postgres:PASSWORD@HOST:PORT/railway
# Neon:     postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# DESARROLLO LOCAL (opcional — instalar PostgreSQL o usar Docker):
# docker run -e POSTGRES_PASSWORD=footix -p 5432:5432 postgres:15
# DATABASE_URL="postgresql://postgres:footix@localhost:5432/footix"

# ── Autenticación ───────────────────────────────────────────────
# OBLIGATORIO: cambiar por una clave aleatoria de 32+ caracteres
# Generar en terminal: openssl rand -hex 32
JWT_SECRET="CAMBIA_ESTO_EN_PRODUCCION_openssl_rand_hex_32"

# ── Servidor ────────────────────────────────────────────────────
PORT=3001
NODE_ENV="production"

# ── CORS: URL del frontend ──────────────────────────────────────
# Desarrollo:
# CLIENT_URL="http://localhost:5173"
# Producción (Vercel):
CLIENT_URL="https://TU-PROYECTO.vercel.app"
